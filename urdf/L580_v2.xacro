<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="L580">

  <material name="yellow"><color rgba="1.0 0.8 0.0 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>

  <link name="dummy_link"/>

  <joint name="dummy_to_base" type="fixed">
    <parent link="dummy_link"/>
    <child link="base_link"/>
    <origin xyz="0 0 2.6" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <mass value="5000.0"/>
      <origin xyz="-2.61002 0.0 -0.48814" rpy="0 0 0"/>
      <inertia ixx="5000.0" ixy="0.0" ixz="500.0" iyy="15000.0" iyz="0.0" izz="13000.0"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/body.STL"/></geometry><material name="yellow"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/body.STL"/></geometry></collision>
  </link>

  <joint name="front_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_wheel_link"/>
    <origin xyz="0.43775 0 -1.5816" rpy="-1.57 -1.57 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="front_wheel_link">
    <inertial>
      <mass value="500.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="100.0" ixy="0.0" ixz="0.0" iyy="100.0" iyz="0.0" izz="50.0"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/wheel.STL"/></geometry><material name="black"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/wheel.STL"/></geometry></collision>
  </link>

  <joint name="rear_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_wheel_link"/>
    <origin xyz="-3.33631 0 -1.5816" rpy="-1.57 -1.57 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="rear_wheel_link">
    <inertial>
      <mass value="500.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="100.0" ixy="0.0" ixz="0.0" iyy="100.0" iyz="0.0" izz="50.0"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/wheel.STL"/></geometry><material name="black"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/wheel.STL"/></geometry></collision>
  </link>

  <joint name="arm_joint2" type="revolute">
    <parent link="base_link"/>
    <child link="arm_link1"/>
    <origin xyz="-0.25834 0 0.08169" rpy="-1.57 0.40815617 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.5" upper="1.5" effort="50000" velocity="0.5"/>
    <dynamics damping="500.0" friction="50.0"/> 
  </joint>
  <link name="arm_link1">
    <inertial>
      <mass value="100.0"/>
      <origin xyz="1.28313 0.0 0.0" rpy="0 0 0"/>
      <inertia ixx="10.0" ixy="0.0" ixz="0" iyy="25.0" iyz="0.0" izz="28.0"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/arm_link1.STL"/></geometry><material name="yellow"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/arm_link1.STL"/></geometry></collision>
  </link>

  <joint name="arm_joint4" type="revolute">
    <parent link="arm_link1"/>
    <child link="bucket"/>
    <origin xyz="3.26512 0 0" rpy="0 0 -0.329692696"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.0" upper="2.0" effort="30000" velocity="0.5"/>
    <dynamics damping="200.0" friction="20.0"/> 
  </joint>
  <link name="bucket">
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0.81076 -0.35 0.0" rpy="0 0 0"/>
      <inertia ixx="5.0" ixy="0.0" ixz="0.0" iyy="5.0" iyz="0.0" izz="2.0"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/bucket.STL"/></geometry><material name="black"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/bucket.STL"/></geometry></collision>
  </link>

  <joint name="bellcrank_joint" type="revolute">
    <parent link="arm_link1"/>
    <child link="tilt_link1"/>
    <origin xyz="1.85125 -0.53443 0" rpy="0 0 0.436681379"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0" upper="3.0" effort="20000" velocity="1.0"/>
    <dynamics damping="300.0" friction="30.0"/>
  </joint>
  <link name="tilt_link1">
    <inertial>
      <mass value="30.0"/>
      <origin xyz="0.10893 0.0 0.0" rpy="0 0 0"/> 
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="5.0" iyz="0.0" izz="5.5"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/tilt_link1_co2.STL"/></geometry><material name="yellow"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/tilt_link1_co2.STL"/></geometry></collision>
  </link>

  <joint name="tilt_joint3" type="revolute">
    <parent link="tilt_link1"/>
    <child link="tilt_link2"/>
    <origin xyz="0.82217 0.48340 0" rpy="0 0 -1.13446401"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.0" upper="3.0" effort="10000" velocity="1.0"/>
    <dynamics damping="100.0" friction="10.0"/>
  </joint>
  <link name="tilt_link2">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0.45346 0.0 0.0" rpy="0 0 0"/>
      <inertia ixx="0.05" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/tilt_link2.STL"/></geometry><material name="yellow"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/tilt_link2.STL"/></geometry></collision>
  </link>

  <joint name="arm_joint1" type="revolute">
    <parent link="base_link"/>
    <child link="cil_link2"/>
    <origin xyz="-0.30062 0 -0.53381" rpy="-1.57 0.08666653 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.0" upper="1.0" effort="10000" velocity="1.0"/>
    <dynamics damping="50.0" friction="5.0"/>
  </joint>
  <link name="cil_link2">
    <inertial>
      <mass value="15.0"/>
      <origin xyz="0.42516 0 0" rpy="0 0 0"/>
      <inertia ixx="0.2" ixy="0.0" ixz="0.0" iyy="2.0" iyz="0.0" izz="2.0"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/cil2.STL"/></geometry><material name="grey"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/cil2.STL"/></geometry></collision>
  </link>

  <joint name="cil2_joint" type="prismatic">
    <parent link="cil_link2"/>
    <child link="cil_pris_link2"/>
    <origin xyz="0.42917 0 0" rpy="3.14 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="1.0" effort="100000" velocity="0.2"/>
    <dynamics damping="1000.0" friction="100.0"/>
  </joint>
  <link name="cil_pris_link2">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0.49872" rpy="0 0 0"/>
      <inertia ixx="0.5" ixy="0.0" ixz="0.0" iyy="0.5" iyz="0.0" izz="0.05"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/cil2_pris.STL"/></geometry><material name="grey"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/cil2_pris.STL"/></geometry></collision>
  </link>

  <joint name="tilt_joint1" type="revolute">
    <parent link="base_link"/>
    <child link="cil_link1"/>
    <origin xyz="0 0 0" rpy="-1.57 -0.24965842 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.0" upper="1.0" effort="10000" velocity="1.0"/>
    <dynamics damping="50.0" friction="5.0"/>
  </joint>
  <link name="cil_link1">
    <inertial>
      <mass value="15.0"/>
      <origin xyz="0.42516 0 0" rpy="0 0 0"/>
      <inertia ixx="0.2" ixy="0.0" ixz="0.0" iyy="2.0" iyz="0.0" izz="2.0"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/cil1.STL"/></geometry><material name="grey"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/cil1.STL"/></geometry></collision>
  </link>

  <joint name="cil1_joint" type="prismatic">
    <parent link="cil_link1"/>
    <child link="cil_pris_link1"/>
    <origin xyz="0.37347 0 0" rpy="3.14 -1.57 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="0.7" effort="100000" velocity="0.2"/>
    <dynamics damping="1000.0" friction="100.0"/>
  </joint>
  <link name="cil_pris_link1">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0.49872" rpy="0 0 0"/>
      <inertia ixx="0.5" ixy="0.0" ixz="0.0" iyy="0.5" iyz="0.0" izz="0.05"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/cil1_pris.STL"/></geometry><material name="grey"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/cil1_pris.STL"/></geometry></collision>
  </link>

  <gazebo>
    <joint name="lift_loop_joint" type="revolute">
      <parent>cil_pris_link2</parent>
      <child>arm_link1</child>
      <pose>0 0 1.33635 3.14 -1.57 0</pose> 
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-6.28</lower>
          <upper>6.28</upper>
        </limit>
        <dynamics>
          <damping>100.0</damping>
          <friction>10.0</friction>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>true</implicit_spring_damper>
          <cfm>0.001</cfm>
          <erp>0.2</erp>
        </ode>
      </physics>
    </joint>

    <joint name="tilt_piston_loop" type="revolute">
      <parent>cil_pris_link1</parent>
      <child>tilt_link1</child>
      <pose>0.89626 0 0 3.14 -1.57 0</pose> 
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-6.28</lower>
          <upper>6.28</upper>
        </limit>
        <dynamics>
          <damping>100.0</damping>
          <friction>10.0</friction>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>true</implicit_spring_damper>
          <cfm>0.001</cfm>
          <erp>0.2</erp>
        </ode>
      </physics>
    </joint>

    <joint name="dogbone_bucket_loop" type="revolute">
      <parent>tilt_link2</parent>
      <child>bucket</child>
      <pose>0.92750 0 0 0 0 0.368089939</pose> 
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-6.28</lower>
          <upper>6.28</upper>
        </limit>
        <dynamics>
          <damping>50.0</damping>
          <friction>5.0</friction>
        </dynamics>
      </axis>
      <physics>
        <ode>
          <implicit_spring_damper>true</implicit_spring_damper>
          <cfm>0.001</cfm>
          <erp>0.2</erp>
        </ode>
      </physics>
    </joint>

    <physics type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
      <ode>
        <solver>
          <type>quick</type>
          <iters>150</iters>
          <sor>1.3</sor>
        </solver>
        <constraints>
          <cfm>0.0</cfm>
          <erp>0.2</erp>
          <contact_max_correcting_vel>100.0</contact_max_correcting_vel>
          <contact_surface_layer>0.001</contact_surface_layer>
        </constraints>
      </ode>
    </physics>
  </gazebo>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="front_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position">
            <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
    </joint>
    <joint name="rear_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position">
            <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
    </joint>

    <joint name="cil1_joint">
        <command_interface name="velocity"/>
        <state_interface name="position">
            <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
    </joint>
    <joint name="cil2_joint">
        <command_interface name="velocity"/>
        <state_interface name="position">
            <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
        <parameters>$(find loader_sim_pkg)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="front_wheel_link">
      <surface>
        <friction>
          <ode>
            <slip1>0.0</slip1>
            <slip2>0.0</slip2>
            <mu>1.2</mu>
            <mu2>1.2</mu2>
          </ode>
        </friction>
      </surface>
      <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="rear_wheel_link">
      <surface>
        <friction>
          <ode>
            <slip1>0.0</slip1>
            <slip2>0.0</slip2>
            <mu>1.2</mu>
            <mu2>1.2</mu2>
          </ode>
        </friction>
      </surface>
      <material>Gazebo/Grey</material>
  </gazebo>

</robot>
