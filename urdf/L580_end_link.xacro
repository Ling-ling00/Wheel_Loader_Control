<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="L580">

  <material name="yellow"><color rgba="1.0 0.8 0.0 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>

  <link name="dummy_link"/>

  <joint name="dummy_to_base" type="fixed">
    <parent link="dummy_link"/>
    <child link="base_link"/>
    <origin xyz="0 0 2.6" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <mass value="5000.0"/>
      <origin xyz="-2.35168  0.0 -0.48814" rpy="0 0 0"/>
      <inertia ixx="5000.0" ixy="0.0" ixz="500.0" iyy="15000.0" iyz="0.0" izz="13000.0"/>
    </inertial>
    <visual>
      <origin xyz="0.25834 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/body.STL"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0.25834 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/body.STL"/></geometry>
    </collision>
  </link>

  <joint name="front_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_wheel_link"/>
    <origin xyz="0.69609 0 -1.5816" rpy="-1.57 -1.57 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="front_wheel_link">
    <inertial>
      <mass value="500.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="100.0" ixy="0.0" ixz="0.0" iyy="100.0" iyz="0.0" izz="50.0"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/wheel.STL"/></geometry><material name="black"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/wheel.STL"/></geometry></collision>
  </link>

  <joint name="rear_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_wheel_link"/>
    <origin xyz="-3.07797 0 -1.5816" rpy="-1.57 -1.57 0"/>
    <axis xyz="0 0 1"/>
  </joint>
  <link name="rear_wheel_link">
    <inertial>
      <mass value="500.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="100.0" ixy="0.0" ixz="0.0" iyy="100.0" iyz="0.0" izz="50.0"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/wheel.STL"/></geometry><material name="black"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/wheel.STL"/></geometry></collision>
  </link>

  <joint name="arm_joint2" type="revolute">
    <parent link="base_link"/>
    <child link="arm_link1"/>
    <origin xyz="0 0 0.08169" rpy="-1.57 0 0"/> <!-- rpy="-1.57 0.40815617 0" -->
    <axis xyz="0 0 1"/>
    <limit lower="-1.5" upper="1.5" effort="50000" velocity="0.5"/>
    <dynamics damping="500.0" friction="50.0"/> 
  </joint>
  <link name="arm_link1">
    <inertial>
      <mass value="100.0"/>
      <origin xyz="1.28313 0.0 0.0" rpy="0 0 0"/>
      <inertia ixx="10.0" ixy="0.0" ixz="0" iyy="25.0" iyz="0.0" izz="28.0"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/arm_link1.STL"/></geometry><material name="yellow"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/arm_link1.STL"/></geometry></collision>
  </link>

  <joint name="arm_joint4" type="revolute">
    <parent link="arm_link1"/>
    <child link="bucket"/>
    <origin xyz="3.26512 0 0" rpy="0 0 0"/> <!-- rpy="0 0 -0.329692696" -->
    <axis xyz="0 0 1"/>
    <limit lower="-2.0" upper="2.0" effort="30000" velocity="0.5"/>
    <dynamics damping="200.0" friction="20.0"/> 
  </joint>
  <link name="bucket">
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0.81076 -0.35 0.0" rpy="0 0 0"/>
      <inertia ixx="5.0" ixy="0.0" ixz="0.0" iyy="5.0" iyz="0.0" izz="2.0"/>
    </inertial>
    <visual><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/bucket.STL"/></geometry><material name="black"/></visual>
    <collision><geometry><mesh filename="file:///$(find loader_sim_pkg)/meshes/bucket.STL"/></geometry></collision>
  </link>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="front_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position">
            <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
    </joint>
    <joint name="rear_wheel_joint">
        <command_interface name="velocity"/>
        <state_interface name="position">
            <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
    </joint>

    <joint name="arm_joint2">
        <command_interface name="velocity"/>
        <command_interface name="position">
            <param name="min">-3.14</param>
            <param name="max">3.14</param>
        </command_interface>
        <state_interface name="position">
            <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
    </joint>
    <joint name="arm_joint4">
        <command_interface name="velocity"/>
        <command_interface name="position">
            <param name="min">-3.14</param>
            <param name="max">3.14</param>
        </command_interface>
        <state_interface name="position">
            <param name="initial_value">0.0</param>
        </state_interface>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="libgazebo_ros2_control.so" name="gazebo_ros2_control">
        <parameters>$(find loader_sim_pkg)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <gazebo reference="front_wheel_link">
      <surface>
        <friction>
          <ode>
            <slip1>0.0</slip1>
            <slip2>0.0</slip2>
            <mu>10.0</mu>
            <mu2>10.0</mu2>
          </ode>
        </friction>
      </surface>
      <material>Gazebo/Grey</material>
  </gazebo>

  <gazebo reference="rear_wheel_link">
      <surface>
        <friction>
          <ode>
            <slip1>0.0</slip1>
            <slip2>0.0</slip2>
            <mu>10.0</mu>
            <mu2>10.0</mu2>
          </ode>
        </friction>
      </surface>
      <material>Gazebo/Grey</material>
  </gazebo>

</robot>
